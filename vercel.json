{
    "version": 2,
    "name": "meetx",
    "experimentalServices": {
        "frontend": {
            "root": "frontend",
            "framework": "vite",
            "buildCommand": "npm run build",
            "routePrefix": "/"
        },
        "backend": {
            "root": "backend",
            "framework": "express",
            "buildCommand": "npm install",
            "functions": "src",
            "routePrefix": "/_/backend"
        }
    }
}
