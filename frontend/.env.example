VITE_SIGNALING_URL=http://localhost:4000

# Optional: override ICE servers on the client (JSON array string)
# If omitted, the client will use the list sent by the backend via Socket.IO `ice-servers`,
# and falls back to public STUN servers.
# VITE_ICE_SERVERS=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"stun:global.stun.twilio.com:3478"}]
